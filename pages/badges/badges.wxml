<view class="container">
  <view class="banner">
    <view class="banner-title">🏅 里程碑徽章</view>
    <view class="banner-sub">已获得 {{earnedCount}} / {{badges.length}} 个</view>
    <!-- 进度条 -->
    <view class="progress-bar">
      <view class="progress-fill" style="width:{{progressPct}}%"></view>
    </view>
  </view>

  <view class="badges-grid">
    <view class="badge-item {{item.earned ? 'earned' : 'locked'}}" wx:for="{{badges}}" wx:key="days">
      <view class="badge-icon">{{item.icon}}</view>
      <view class="badge-days">{{item.days}}天</view>
      <view class="badge-name">{{item.name}}</view>
      <view wx:if="{{item.earned}}" class="badge-tag earned-tag">已获得</view>
      <view wx:else class="badge-tag locked-tag">还差{{item.daysLeft}}天</view>
    </view>
  </view>
</view>
