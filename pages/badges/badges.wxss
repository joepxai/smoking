.container { background: #EEF2FF; min-height: 100vh; padding-bottom: 48rpx; }

.banner {
  background: linear-gradient(145deg, #4F72FF, #7C5CFC);
  padding: 40rpx 40rpx 48rpx;
  border-radius: 0 0 48rpx 48rpx;
  color: #fff;
  margin-bottom: 32rpx;
}
.banner-title { font-size: 36rpx; font-weight: 700; margin-bottom: 8rpx; }
.banner-sub { font-size: 24rpx; opacity: 0.75; margin-bottom: 20rpx; }
.progress-bar {
  background: rgba(255,255,255,0.25);
  border-radius: 20rpx;
  height: 12rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 20rpx;
  transition: width 0.3s;
}

.badges-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 32rpx;
}
.badge-item {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(79,114,255,0.08);
  box-sizing: border-box;
  position: relative;
}
.badge-item.locked { opacity: 0.5; }
.badge-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.badge-days { font-size: 40rpx; font-weight: 800; color: #4F72FF; line-height: 1; }
.badge-item.locked .badge-days { color: #CBD5E1; }
.badge-name { font-size: 24rpx; color: #475569; margin: 8rpx 0; }
.badge-tag {
  display: inline-block;
  font-size: 20rpx;
  border-radius: 40rpx;
  padding: 4rpx 16rpx;
}
.earned-tag { background: #EEF2FF; color: #4F72FF; }
.locked-tag { background: #F1F5F9; color: #94A3B8; }
