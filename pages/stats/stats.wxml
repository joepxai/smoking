<view class="container">
  <!-- 数据卡片 -->
  <view class="card">
    <view class="card-title">📊 戒烟数据</view>
    <view class="row"><text class="lbl">开始日期</text><text class="val">{{startDate || '未设置'}}</text></view>
    <view class="row"><text class="lbl">连续天数</text><text class="val green">{{streak}} 天</text></view>
    <view class="row"><text class="lbl">累计成功</text><text class="val">{{totalDays}} 天</text></view>
    <view class="row"><text class="lbl">节省金钱</text><text class="val green">¥{{moneySaved}}</text></view>
    <view class="row"><text class="lbl">相当于</text><text class="val">{{cigarettesAvoided}} 支烟</text></view>
  </view>

  <!-- 健康恢复时间线 -->
  <view class="card">
    <view class="card-title">💚 健康恢复进度</view>
    <view class="timeline">
      <view class="tl-item {{item.done ? 'done' : 'pending'}}" wx:for="{{healthMilestones}}" wx:key="hours">
        <view class="tl-dot"></view>
        <view class="tl-content">
          <view class="tl-time">{{item.label}}</view>
          <view class="tl-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 最近打卡记录 -->
  <view class="card">
    <view class="card-title">📅 最近 7 天</view>
    <view class="week-row">
      <view class="day-item {{item.status}}" wx:for="{{recentDays}}" wx:key="date">
        <view class="day-dot"></view>
        <view class="day-label">{{item.weekday}}</view>
      </view>
    </view>
  </view>
</view>
