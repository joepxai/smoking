.container { padding-bottom: 40rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin: 24rpx 32rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06); }
.card-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }

.row { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.row:last-child { border-bottom: none; }
.lbl { font-size: 26rpx; color: #666; }
.val { font-size: 28rpx; color: #333; font-weight: 500; }
.val.green { color: #4CAF50; }

/* 时间线 */
.timeline { padding-left: 16rpx; }
.tl-item { display: flex; align-items: flex-start; margin-bottom: 28rpx; position: relative; }
.tl-item:last-child { margin-bottom: 0; }
.tl-dot { width: 20rpx; height: 20rpx; border-radius: 50%; margin-top: 8rpx; margin-right: 24rpx; flex-shrink: 0; }
.tl-item.done .tl-dot { background: #4CAF50; }
.tl-item.pending .tl-dot { background: #ddd; }
.tl-time { font-size: 24rpx; font-weight: 600; }
.tl-item.done .tl-time { color: #4CAF50; }
.tl-item.pending .tl-time { color: #bbb; }
.tl-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.tl-item.done .tl-desc { color: #666; }

/* 最近7天 */
.week-row { display: flex; justify-content: space-between; }
.day-item { flex: 1; text-align: center; }
.day-dot { width: 32rpx; height: 32rpx; border-radius: 50%; margin: 0 auto 8rpx; }
.day-item.success .day-dot { background: #4CAF50; }
.day-item.fail .day-dot { background: #FF7043; }
.day-item.empty .day-dot { background: #eee; }
.day-label { font-size: 20rpx; color: #999; }
