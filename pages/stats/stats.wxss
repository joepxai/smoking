.container { background: #EEF2FF; min-height: 100vh; padding-bottom: 48rpx; }

.banner {
  background: linear-gradient(145deg, #4F72FF, #7C5CFC);
  padding: 40rpx 40rpx 56rpx;
  border-radius: 0 0 48rpx 48rpx;
  color: #fff;
  margin-bottom: 32rpx;
}
.banner-title { font-size: 36rpx; font-weight: 700; margin-bottom: 8rpx; }
.banner-sub { font-size: 24rpx; opacity: 0.75; }

/* 网格 */
.grid-row { display: flex; gap: 20rpx; margin: 0 32rpx 20rpx; }
.grid-card {
  flex: 1; border-radius: 20rpx; padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.grid-card.blue { background: linear-gradient(135deg, #4F72FF, #6B8EFF); }
.grid-card.purple { background: linear-gradient(135deg, #7C5CFC, #A78BFA); }
.grid-card.green { background: linear-gradient(135deg, #10B981, #34D399); }
.grid-card.orange { background: linear-gradient(135deg, #F59E0B, #FCD34D); }
.grid-lbl { font-size: 22rpx; color: rgba(255,255,255,0.8); margin-bottom: 8rpx; }
.grid-val { font-size: 56rpx; font-weight: 800; color: #fff; line-height: 1; }
.grid-unit { font-size: 22rpx; color: rgba(255,255,255,0.8); margin-top: 4rpx; }

/* 卡片 */
.card {
  background: #fff; border-radius: 20rpx; padding: 32rpx;
  margin: 0 32rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(79,114,255,0.08);
}
.card-title { font-size: 28rpx; font-weight: 700; color: #1E293B; margin-bottom: 28rpx; }

/* 时间线 */
.timeline {}
.tl-item { display: flex; margin-bottom: 0; }
.tl-left { display: flex; flex-direction: column; align-items: center; margin-right: 20rpx; width: 20rpx; }
.tl-dot { width: 20rpx; height: 20rpx; border-radius: 50%; flex-shrink: 0; }
.tl-item.done .tl-dot { background: #4F72FF; }
.tl-item.pending .tl-dot { background: #E2E8F0; }
.tl-line { width: 2rpx; flex: 1; min-height: 32rpx; background: #E2E8F0; margin: 4rpx 0; }
.tl-content { padding-bottom: 28rpx; flex: 1; }
.tl-time { font-size: 26rpx; font-weight: 600; }
.tl-item.done .tl-time { color: #4F72FF; }
.tl-item.pending .tl-time { color: #CBD5E1; }
.tl-desc { font-size: 22rpx; margin-top: 4rpx; }
.tl-item.done .tl-desc { color: #64748B; }
.tl-item.pending .tl-desc { color: #CBD5E1; }

/* 最近7天 */
.week-row { display: flex; justify-content: space-between; margin-bottom: 20rpx; }
.day-item { flex: 1; text-align: center; }
.day-dot { width: 40rpx; height: 40rpx; border-radius: 50%; margin: 0 auto 8rpx; }
.day-dot.success { background: #4F72FF; }
.day-dot.fail { background: #F87171; }
.day-dot.empty { background: #E2E8F0; }
.day-label { font-size: 20rpx; color: #94A3B8; }
.week-legend { display: flex; gap: 24rpx; }
.legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; color: #94A3B8; }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.legend-dot.success { background: #4F72FF; }
.legend-dot.fail { background: #F87171; }
.legend-dot.empty { background: #E2E8F0; }
