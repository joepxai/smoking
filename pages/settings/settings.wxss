.container { background: #EEF2FF; min-height: 100vh; padding-bottom: 60rpx; }

.banner {
  background: linear-gradient(145deg, #4F72FF, #7C5CFC);
  padding: 40rpx 40rpx 56rpx;
  border-radius: 0 0 48rpx 48rpx;
  color: #fff;
  margin-bottom: 32rpx;
}
.banner-title { font-size: 36rpx; font-weight: 700; margin-bottom: 8rpx; }
.banner-sub { font-size: 24rpx; opacity: 0.75; }

.card {
  background: #fff; border-radius: 20rpx; padding: 8rpx 32rpx;
  margin: 0 32rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(79,114,255,0.08);
}

.field {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 0; border-bottom: 1rpx solid #F1F5F9;
}
.field.last { border-bottom: none; }
.field-left { display: flex; align-items: center; gap: 16rpx; }
.field-icon { font-size: 32rpx; }
.field-label { font-size: 28rpx; color: #1E293B; font-weight: 500; }
.field-value { font-size: 26rpx; color: #4F72FF; font-weight: 500; }
.field-value.placeholder { color: #CBD5E1; }
.field-input { font-size: 26rpx; color: #4F72FF; text-align: right; width: 240rpx; }

.save-btn {
  background: linear-gradient(135deg, #4F72FF, #7C5CFC);
  color: #fff; border-radius: 20rpx;
  font-size: 30rpx; font-weight: 600;
  padding: 28rpx 0; margin: 0 32rpx 24rpx;
  border: none;
}

.danger-card { padding: 28rpx 32rpx; }
.danger-title { font-size: 26rpx; font-weight: 600; color: #EF4444; margin-bottom: 8rpx; }
.danger-desc { font-size: 22rpx; color: #94A3B8; margin-bottom: 24rpx; }
.reset-btn {
  background: #FFF1F0; color: #EF4444;
  border: 1rpx solid #FECACA; border-radius: 16rpx;
  font-size: 26rpx; padding: 20rpx 0;
}
