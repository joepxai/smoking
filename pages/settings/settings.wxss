.container { padding: 32rpx 32rpx 60rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06); }
.card-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }

.field { padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.field.last { border-bottom: none; }
.field-label { font-size: 24rpx; color: #999; margin-bottom: 10rpx; }
.field-value { font-size: 28rpx; color: #333; }
.field-value.placeholder { color: #bbb; }
.field-input { font-size: 28rpx; color: #333; width: 100%; }

.save-btn {
  background: #4CAF50; color: #fff; border-radius: 50rpx;
  font-size: 30rpx; padding: 24rpx 0; margin-bottom: 24rpx;
  border: none;
}

.danger-card { border: 1rpx solid #ffebee; background: #fff; }
.reset-btn {
  background: #fff; color: #f44336; border: 1rpx solid #f44336;
  border-radius: 50rpx; font-size: 28rpx; padding: 20rpx 0;
}
