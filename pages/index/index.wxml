<view class="container">

  <!-- 顶部 Hero 渐变区 -->
  <view class="hero">
    <view class="hero-top">
      <view class="hero-label">连续戒烟</view>
      <view class="hero-reason" wx:if="{{reason}}">💪 {{reason}}</view>
    </view>
    <view class="hero-number-row">
      <text class="hero-number">{{streak}}</text>
      <text class="hero-unit">天</text>
    </view>
    <view class="hero-sub">累计成功 {{totalDays}} 天 · 已节省 ¥{{moneySaved}}</view>

    <!-- 周历打卡条 -->
    <view class="week-bar">
      <view class="week-item {{item.status}}" wx:for="{{recentDays}}" wx:key="date">
        <view class="week-dot"></view>
        <view class="week-day">{{item.weekday}}</view>
      </view>
    </view>
  </view>

  <!-- 今日打卡卡片 -->
  <view class="card checkin-card">
    <view class="checkin-date-row">
      <text class="checkin-title">今日打卡</text>
      <text class="checkin-date">{{today}}</text>
    </view>

    <view wx:if="{{todayRecord === null}}" class="btn-group">
      <button class="btn-success" bindtap="onCheckin" data-status="success">
        <text class="btn-icon">✅</text> 今天成功了
      </button>
      <button class="btn-fail" bindtap="onCheckin" data-status="fail">
        <text class="btn-icon">😔</text> 今天失败了
      </button>
    </view>

    <view wx:else class="checked-result">
      <view wx:if="{{todayRecord === 'success'}}" class="result-badge success">
        <text>✅ 今日已打卡成功，继续加油！</text>
      </view>
      <view wx:else class="result-badge fail">
        <text>😔 没关系，明天重新开始</text>
      </view>
    </view>
  </view>

  <!-- 数据网格 -->
  <view class="grid-row">
    <view class="grid-card">
      <view class="grid-icon">🗓️</view>
      <view class="grid-val">{{daysSinceStart}}</view>
      <view class="grid-lbl">坚持天数</view>
    </view>
    <view class="grid-card">
      <view class="grid-icon">💰</view>
      <view class="grid-val">¥{{moneySaved}}</view>
      <view class="grid-lbl">节省金钱</view>
    </view>
  </view>
  <view class="grid-row">
    <view class="grid-card">
      <view class="grid-icon">🚬</view>
      <view class="grid-val">{{cigarettesAvoided}}</view>
      <view class="grid-lbl">少抽支数</view>
    </view>
    <view class="grid-card">
      <view class="grid-icon">🏅</view>
      <view class="grid-val">{{badgeCount}}</view>
      <view class="grid-lbl">获得徽章</view>
    </view>
  </view>

  <!-- 未设置提示 -->
  <view wx:if="{{!hasSettings}}" class="card setup-tip" bindtap="goSettings">
    <text>👆 先去设置开始日期和戒烟理由</text>
  </view>

</view>
