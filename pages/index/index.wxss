.container {
  padding-bottom: 48rpx;
  background: #EEF2FF;
  min-height: 100vh;
}

/* Hero 渐变区 */
.hero {
  background: linear-gradient(145deg, #4F72FF 0%, #7C5CFC 100%);
  padding: 48rpx 40rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  color: #fff;
  margin-bottom: 32rpx;
}
.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.hero-label {
  font-size: 26rpx;
  opacity: 0.85;
  font-weight: 500;
}
.hero-reason {
  font-size: 22rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 40rpx;
  padding: 6rpx 20rpx;
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.hero-number-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 8rpx;
}
.hero-number {
  font-size: 128rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -4rpx;
}
.hero-unit {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  margin-left: 8rpx;
  opacity: 0.85;
}
.hero-sub {
  font-size: 24rpx;
  opacity: 0.75;
  margin-bottom: 32rpx;
}

/* 周历打卡条 */
.week-bar {
  display: flex;
  justify-content: space-between;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
}
.week-item {
  flex: 1;
  text-align: center;
}
.week-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  margin: 0 auto 8rpx;
  background: rgba(255,255,255,0.3);
}
.week-item.success .week-dot {
  background: #fff;
}
.week-item.fail .week-dot {
  background: rgba(255, 100, 100, 0.7);
}
.week-day {
  font-size: 20rpx;
  opacity: 0.8;
}

/* 打卡卡片 */
.checkin-card {
  margin: 0 32rpx 24rpx;
}
.checkin-date-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}
.checkin-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E293B;
}
.checkin-date {
  font-size: 24rpx;
  color: #94A3B8;
}
.btn-group {
  display: flex;
  gap: 20rpx;
}
.btn-success, .btn-fail {
  flex: 1;
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
  border: none;
  font-weight: 600;
}
.btn-success {
  background: linear-gradient(135deg, #4F72FF, #7C5CFC);
  color: #fff;
}
.btn-fail {
  background: #F1F5F9;
  color: #64748B;
}
.result-badge {
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}
.result-badge.success {
  background: #EEF2FF;
  color: #4F72FF;
}
.result-badge.fail {
  background: #FFF1F0;
  color: #F87171;
}

/* 数据网格 */
.grid-row {
  display: flex;
  gap: 20rpx;
  margin: 0 32rpx 20rpx;
}
.grid-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(79, 114, 255, 0.08);
  text-align: center;
}
.grid-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}
.grid-val {
  font-size: 40rpx;
  font-weight: 800;
  color: #4F72FF;
  margin-bottom: 6rpx;
}
.grid-lbl {
  font-size: 22rpx;
  color: #94A3B8;
}

/* 未设置提示 */
.setup-tip {
  text-align: center;
  color: #4F72FF;
  font-size: 28rpx;
  border: 2rpx dashed #4F72FF;
  background: #EEF2FF;
  margin: 0 32rpx;
}
