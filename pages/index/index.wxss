.container { padding-bottom: 40rpx; }

.hero-card {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 0 0 40rpx 40rpx;
  padding: 60rpx 40rpx 50rpx;
  text-align: center;
  color: #fff;
}
.streak-label { font-size: 28rpx; opacity: 0.85; margin-bottom: 8rpx; }
.streak-number { font-size: 120rpx; font-weight: 700; line-height: 1; }
.streak-unit { font-size: 32rpx; opacity: 0.85; margin-top: 4rpx; }
.reason { font-size: 26rpx; margin-top: 24rpx; opacity: 0.9; background: rgba(255,255,255,0.2); border-radius: 40rpx; padding: 8rpx 24rpx; display: inline-block; }

.checkin-card { text-align: center; }
.checkin-title { font-size: 30rpx; font-weight: 600; color: #333; }
.checkin-date { font-size: 24rpx; color: #999; margin: 8rpx 0 32rpx; }

.btn-group { display: flex; gap: 24rpx; }
.btn-success, .btn-fail {
  flex: 1; border-radius: 50rpx; font-size: 28rpx; padding: 20rpx 0;
  border: none;
}
.btn-success { background: #4CAF50; color: #fff; }
.btn-fail { background: #f5f5f5; color: #666; }

.checked-result { padding: 16rpx 0; }
.result-success { color: #4CAF50; font-size: 30rpx; font-weight: 600; }
.result-fail { color: #FF7043; font-size: 30rpx; }

.stats-row { display: flex; align-items: center; padding: 24rpx 32rpx; }
.stat-item { flex: 1; text-align: center; }
.stat-val { font-size: 40rpx; font-weight: 700; color: #4CAF50; }
.stat-lbl { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.stat-divider { width: 1rpx; height: 60rpx; background: #eee; }

.setup-tip {
  text-align: center; color: #4CAF50; font-size: 28rpx;
  border: 2rpx dashed #4CAF50; background: #f9fff9;
}
